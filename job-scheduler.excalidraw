    {
      "id": "8w9K3Cb7scdZ_HKKI3RdL",
      "type": "text",
      "x": 268.3230780080464,
      "y": 1036.1073843472095,
      "width": 489.8056445679126,
      "height": 382.7979437635902,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "oLwsrdEQZ_F84PDDy4w7D"
      ],
      "frameId": null,
      "index": "b1r",
      "roundness": null,
      "seed": 2008541841,
      "version": 1018,
      "versionNonce": 1813489599,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772550247166,
      "link": null,
      "locked": false,
      "text": "UserId injected as an header from the JWT token\n\n- POST /v1/jobs -> job-id\nRequest Body \n{\n    - jobName\n    - interval (like PT3H)\n    - isRecurring\n    - url\n    - httpBody (JSON)\n}\n\n- DELETE /v1/jobs/{job-id}\n\n- GET /v1/jobs -> List of jobs with pagination\n\n- GET /v1/jobs/{job-id}/history\n\n ",
      "fontSize": 16.117808158466953,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "UserId injected as an header from the JWT token\n\n- POST /v1/jobs -> job-id\nRequest Body \n{\n    - jobName\n    - interval (like PT3H)\n    - isRecurring\n    - url\n    - httpBody (JSON)\n}\n\n- DELETE /v1/jobs/{job-id}\n\n- GET /v1/jobs -> List of jobs with pagination\n\n- GET /v1/jobs/{job-id}/history\n\n ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "-l5O9L83l4AwEqhCRIfJ2",
      "type": "text",
      "x": 285.25791112375373,
      "y": 1646.5789775342812,
      "width": 425.0330810546875,
      "height": 602.4037519883373,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
