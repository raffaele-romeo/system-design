      "isDeleted": false,
      "boundElements": null,
      "updated": 1772552636793,
      "link": null,
      "locked": false,
      "text": "job-schedules.\n\n- id (sk)\n- userId (pk)\n- interval  \n- name\n- url\n- httpBody\n- isRecurring\n\ntask-schedules\n- id \n- nextExecutionTimeBucket (pk)\n- job-id (sk)\n- status (SCHEDULED, NOT_STARTED)\n\njob-history\n- id\n- job-id (pk)\n- status (RUNNING, FAILED,COMPLETED)\n- executedAt (sk)\n- attemptsCount\n- lastHttpStatus\n- lastError",
      "fontSize": 20.08012506627791,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "job-schedules.\n\n- id (sk)\n- userId (pk)\n- interval  \n- name\n- url\n- httpBody\n- isRecurring\n\ntask-schedules\n- id \n- nextExecutionTimeBucket (pk)\n- job-id (sk)\n- status (SCHEDULED, NOT_STARTED)\n\njob-history\n- id\n- job-id (pk)\n- status (RUNNING, FAILED,COMPLETED)\n- executedAt (sk)\n- attemptsCount\n- lastHttpStatus\n- lastError",
      "autoResize": true,
      "lineHeight": 1.25
    },
