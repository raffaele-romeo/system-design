    },
    {
      "id": "iCgAXgp9kVKuQ3XaK7uq2",
      "type": "text",
      "x": 234.43288463167312,
      "y": 531.6203662601522,
      "width": 669.306640625,
      "height": 110.37205800672704,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1q",
      "roundness": null,
      "seed": 1871410494,
      "version": 1493,
      "versionNonce": 849512766,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774175330337,
      "link": null,
      "locked": false,
      "text": "Non Functional Requirements\n- Restricted networks with no open inbound ports\n- Pipelines should be resiliant to failures, by storing checkpoint state and\nrestart from there",
      "fontSize": 20.43927000124575,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "znJOohi9bCFPsoB97a-vB",
      "originalText": "Non Functional Requirements\n- Restricted networks with no open inbound ports\n- Pipelines should be resiliant to failures, by storing checkpoint state and restart from there",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "Lk2y3YGZqlXOJJ035zPxW",
      "type": "rectangle",
      "x": 230.9771861829767,
      "y": 777.1269675133899,
      "width": 723.9961497674611,
      "height": 390.0916117211038,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
