      "seed": 1531054754,
      "version": 1170,
      "versionNonce": 155961314,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774175326109,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- Ability for the user to define, edit and run data pipelines from a UI, by\ndefining configuration for source, sink and processing logic\n- Support for both streaming and batch dataset\n- Deploy pipelines to SaaS cloud or edge devices",
      "fontSize": 20.43927000124575,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "eSUOEnjgA9sk79N06bhHz",
      "originalText": "Functional Requirements\n- Ability for the user to define, edit and run data pipelines from a UI, by defining configuration for source, sink and processing logic\n- Support for both streaming and batch dataset\n- Deploy pipelines to SaaS cloud or edge devices",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "znJOohi9bCFPsoB97a-vB",
      "type": "rectangle",
      "x": 229.43288463167312,
      "y": 466.8063952635157,
      "width": 710.2228859861834,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1p",
      "roundness": {
        "type": 3
      },
