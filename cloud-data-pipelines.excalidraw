    {
      "id": "fCSp7p4YlhOgyS8kXQ5yN",
      "type": "text",
      "x": 234.39584027168635,
      "y": 248.56211404750087,
      "width": 651.6756591796875,
      "height": 137.9650725084088,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1g",
