    },
    {
      "id": "-pxrc0RbW7oP3RGLEBNGz",
      "type": "text",
      "x": 235.9771861829767,
      "y": 806.6146863638512,
      "width": 675.4970092773438,
      "height": 331.1161740201811,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1s",
      "roundness": null,
      "seed": 1570953150,
      "version": 2255,
      "versionNonce": 1555367678,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774176043183,
      "link": null,
      "locked": false,
      "text": "API Design\n- POST /v1/pipelines -> creates a new pipiline given the configuration\nprovided in the body\n- GET /v1/pipelines - list the created pipelines with information like which\nones are currently running\n- POST /v1/pipelines/{id}/deploy - Deploys the pipeline \n- POST /v1/pipelines/{id}/stop - Stops the running pipeline\n\n- POST /v1/datasources -> creates a new datasource configuration\n- GET /v1/datasources -> list the defined datasources configuration \n\n",
      "fontSize": 20.43927000124575,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "Lk2y3YGZqlXOJJ035zPxW",
      "originalText": "API Design\n- POST /v1/pipelines -> creates a new pipiline given the configuration provided in the body\n- GET /v1/pipelines - list the created pipelines with information like which ones are currently running\n- POST /v1/pipelines/{id}/deploy - Deploys the pipeline \n- POST /v1/pipelines/{id}/stop - Stops the running pipeline\n\n- POST /v1/datasources -> creates a new datasource configuration\n- GET /v1/datasources -> list the defined datasources configuration \n\n",
      "autoResize": true,
      "lineHeight": 1.35
    },
