      "seed": 1570953150,
      "version": 2334,
      "versionNonce": 1496485246,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774186139400,
      "link": null,
      "locked": false,
      "text": "\n\nAPI Design\n- POST /v1/pipelines -> creates a new pipiline given the configuration\nprovided in the body\n- GET /v1/pipelines - list the created pipelines with information like which\nones are currently running\n- POST /v1/pipelines/{id}/deploy - Deploys the pipeline to customer\nenvironment\n- POST /v1/pipelines/{id}/stop - Stops the running pipeline\n\n- POST /v1/datasources -> creates a new datasource configuration, with\nrelated schemas information\n- GET /v1/datasources -> list the defined datasources configurations \n\n",
      "fontSize": 20.43927000124575,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "Lk2y3YGZqlXOJJ035zPxW",
      "originalText": "\n\nAPI Design\n- POST /v1/pipelines -> creates a new pipiline given the configuration provided in the body\n- GET /v1/pipelines - list the created pipelines with information like which ones are currently running\n- POST /v1/pipelines/{id}/deploy - Deploys the pipeline to customer environment\n- POST /v1/pipelines/{id}/stop - Stops the running pipeline\n\n- POST /v1/datasources -> creates a new datasource configuration, with related schemas information\n- GET /v1/datasources -> list the defined datasources configurations \n\n",
      "autoResize": true,
      "lineHeight": 1.35
    },
