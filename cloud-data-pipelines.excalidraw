    {
      "id": "iCgAXgp9kVKuQ3XaK7uq2",
      "type": "text",
      "x": 234.44824099764435,
      "y": 551.3584153218987,
      "width": 669.306640625,
      "height": 110.37205800672704,
      "angle": 0,
