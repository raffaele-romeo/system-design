    {
      "id": "oKbgSLUK21JD9D6m9xYYO",
      "type": "text",
      "x": -551.7812533630363,
      "y": 5552.663631058196,
      "width": 634.2969889081883,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
