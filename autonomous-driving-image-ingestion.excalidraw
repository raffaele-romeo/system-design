      "text": "Design a system that ingest images from\nautonomous vehicle and classify them",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design a system that ingest images from autonomous vehicle and classify them",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Tmffj9S_2KH3-tkXNrptR",
      "type": "rectangle",
      "x": -472.71419029628885,
      "y": 3485.593348915393,
      "width": 440.82421875,
      "height": 800.6015625,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
