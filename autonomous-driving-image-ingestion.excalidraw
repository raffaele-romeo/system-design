      "link": null,
      "locked": false,
      "text": "APIs\n\nPOST /v1/vehicleId/{vehicleId}/images\n{\n- vechicleId\n}\n\nGET /v1/vehicleId{vehcileId}/images/?from=TIME&to=TIME\n{\n\n{images: [\n{\n- imageId\n-classificationType\n-preSignedUrl\n}\n]\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "APIs\n\nPOST /v1/vehicleId/{vehicleId}/images\n{\n- vechicleId\n}\n\nGET /v1/vehicleId{vehcileId}/images/?from=TIME&to=TIME\n{\n\n{images: [\n{\n- imageId\n-classificationType\n-preSignedUrl\n}\n]\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
