      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3Z",
      "roundness": null,
      "seed": 1269095245,
      "version": 502,
      "versionNonce": 1570694819,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774716163090,
      "link": null,
      "locked": false,
      "text": "High Level Design\n\n- mTLS for sensor to authentication to our ingestion service\npublic API\n- ingestion service write to DDB and store the image to s3\n- ML servie will read domain events from Kinesis, and classify the\nimage, writing the classificaiton output to DDB\n- User use query service and they use OAtuh for authentication\n- Vehicle use ingestion service and they use mTLS for\nauthentication over TCP",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "High Level Design\n\n- mTLS for sensor to authentication to our ingestion service public API\n- ingestion service write to DDB and store the image to s3\n- ML servie will read domain events from Kinesis, and classify the image, writing the classificaiton output to DDB\n- User use query service and they use OAtuh for authentication\n- Vehicle use ingestion service and they use mTLS for authentication over TCP",
      "autoResize": false,
      "lineHeight": 1.25
    }
  ],
