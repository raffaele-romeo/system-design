      "link": null,
      "locked": false,
      "text": "DB\n\nTable: VehicleImages\n\nPK (String): vehicle_id#bucket       \"550e8400#2024-01-15\"\nSK (String): captured_at#image_id    \"2024-01-\n15T10:23:45Z#550e...\"\ns3_key      (String)\nclassification (String)\nconfidence  (Number)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DB\n\nTable: VehicleImages\n\nPK (String): vehicle_id#bucket       \"550e8400#2024-01-15\"\nSK (String): captured_at#image_id    \"2024-01-15T10:23:45Z#550e...\"\ns3_key      (String)\nclassification (String)\nconfidence  (Number)",
      "autoResize": false,
      "lineHeight": 1.25
    },
