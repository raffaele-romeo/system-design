    {
      "id": "ifObyfA07se28uVskpYtd",
      "type": "rectangle",
      "x": 223.92300915059002,
      "y": 1288.8152375347977,
      "width": 1245.7395168908154,
      "height": 838.1616132701463,
      "angle": 0,
