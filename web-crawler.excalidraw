    {
      "id": "fcWsyjVlRtQpTQ8BTDEGS",
      "type": "text",
      "x": 255.65141502856147,
      "y": 1322.4501832223552,
      "width": 1191.7160386009582,
      "height": 775.5828561309548,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
