    {
      "id": "Ml791EkhM82u3vt8yywCA",
      "type": "text",
      "x": 1241.167103700459,
      "y": 238.32909005723377,
      "width": 1829.5039981667055,
      "height": 148.7251550483104,
      "angle": 0,
