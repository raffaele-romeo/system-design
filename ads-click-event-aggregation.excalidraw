      "link": null,
      "locked": false,
      "text": "Non Functional Requirements\n- End to end latency should be few minutes\n- High Availability\n- System should handle duplicate events and\nlate events arrival\n- System should be resiliant to partial\nfailures",
      "fontSize": 20.929737156789642,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non Functional Requirements\n- End to end latency should be few minutes\n- High Availability\n- System should handle duplicate events and late events arrival\n- System should be resiliant to partial failures",
      "autoResize": false,
      "lineHeight": 1.25
