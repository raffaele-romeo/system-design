    {
      "id": "EvFNQ4CeXwUD1q6JhpUsV",
      "type": "text",
      "x": 745.9761750650252,
      "y": 235.43490688869542,
      "width": 347.7397155761719,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "m7WU6ov67l4tr_KZsuL-A"
      ],
      "frameId": null,
      "index": "b1m",
      "roundness": null,
      "seed": 27232931,
      "version": 199,
      "versionNonce": 385158851,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772573438941,
      "link": null,
      "locked": false,
      "text": "Assume 10,000,000 DAU\nEach users upload 3 files a day\nEach user has on average 3 devices\n\n30,000,000 daily file uploaded\n300 files uploaded per seconds\nAssume files are maximum 10GB",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Assume 10,000,000 DAU\nEach users upload 3 files a day\nEach user has on average 3 devices\n\n30,000,000 daily file uploaded\n300 files uploaded per seconds\nAssume files are maximum 10GB",
      "autoResize": true,
      "lineHeight": 1.25
    },
